# GoodGame — required environment variables
# Copy this file to .env and fill in the values for local development.
# .env is listed in .gitignore and must NEVER be committed.
#
# In production (Azure Container Apps) these are injected as container env vars.

# ── Django core ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string

DEBUG=True

# Comma-separated list (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,api

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# For local dev, start PostgreSQL with:
#   docker run -d --name postgres -e POSTGRES_DB=goodgame \
#     -e POSTGRES_USER=goodgameadmin -e POSTGRES_PASSWORD=localpass \
#     -p 5432:5432 postgres:16
POSTGRES_DB=goodgame
POSTGRES_USER=goodgameadmin
POSTGRES_PASSWORD=localpass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to make cross-origin requests.
# In local dev the React dev server runs on :5173.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Azure Blob Storage (media uploads) ───────────────────────────────────────
# Leave blank to use local disk storage (MEDIA_ROOT) for dev.
# In production these come from Key Vault via Terraform.
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
